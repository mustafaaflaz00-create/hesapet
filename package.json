{
  "name": "hesap-et-pos",
  "version": "2.2.0",
  "description": "Hesap Et POS - Şarküteri & Kasap Kasa Uygulaması",
  "author": "Hesap Et",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable",
    "publish:win": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.hesapet.pos",
    "productName": "Hesap Et POS",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "musta",
        "repo": "hesap-et-pos",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  }
}
